rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Need photos — Admin only upload, public read
    match /needs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Gallery (before/after) photos — Admin only upload, public read
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
